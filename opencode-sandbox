#!/usr/bin/env bash
set -euo pipefail

# ── Locate this script's directory (where the Dockerfile lives) ────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGE="opencode-sandbox:latest"

# ── Parse opencode-sandbox flags (before passing remainder to opencode) ────────
ISOLATE_VENV=true
CONFIG_SUFFIX=""
PASSTHROUGH_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --isolate-venv)    ISOLATE_VENV=true;  shift ;;
    --no-isolate-venv) ISOLATE_VENV=false; shift ;;
    --config-suffix=*)
      CONFIG_SUFFIX="${1#--config-suffix=}"
      [[ "$CONFIG_SUFFIX" =~ ^[a-zA-Z0-9_-]+$ ]] || { echo "[opencode-sandbox] Error: --config-suffix must contain only letters, digits, dashes, and underscores." >&2; exit 1; }
      shift ;;
    --config-suffix)
      echo "[opencode-sandbox] Error: use --config-suffix=<suffix>, not --config-suffix <suffix>." >&2
      exit 1 ;;
    --update)
      echo "[opencode-sandbox] Rebuilding image '$IMAGE' (--no-cache)..."
      docker build --no-cache \
        --build-arg "UID=$(id -u)" \
        -t "$IMAGE" \
        "$SCRIPT_DIR"
      echo "[opencode-sandbox] Build complete."
      exit 0
      ;;
    --clean-venv)
      VENV_VOLUME="opencode-venv-$(echo "$PWD" | sha256sum | cut -c1-12)"
      echo "[opencode-sandbox] Removing venv volume '$VENV_VOLUME'..."
      if docker volume rm "$VENV_VOLUME" 2>/dev/null; then
        echo "[opencode-sandbox] Done."
      else
        echo "[opencode-sandbox] Volume not found (nothing to remove)."
      fi
      exit 0
      ;;
    --) shift; PASSTHROUGH_ARGS+=("$@"); break ;;
    *)  PASSTHROUGH_ARGS+=("$1"); shift ;;
  esac
done

# ── Compute config paths (affected by --config-suffix) ────────────────────────
OPENCODE_CONFIG_DIR="$HOME/.config/opencode${CONFIG_SUFFIX:+-$CONFIG_SUFFIX}"
OPENCODE_SHARE_DIR="$HOME/.local/share/opencode${CONFIG_SUFFIX:+-$CONFIG_SUFFIX}"
SANDBOX_ENV_FILE="$HOME/.config/opencode-sandbox${CONFIG_SUFFIX:+-$CONFIG_SUFFIX}/.env"

# ── Sanity checks ──────────────────────────────────────────────────────────────
if [[ "$PWD" == *:* ]] || [[ "$HOME" == *:* ]]; then
  echo "[opencode-sandbox] Error: PWD or HOME contains a colon, which breaks Docker/Podman bind-mount volume syntax." >&2
  exit 1
fi

# ── Build image if not present ─────────────────────────────────────────────────
if ! docker image inspect "$IMAGE" > /dev/null 2>&1; then
  echo "[opencode-sandbox] Image '$IMAGE' not found. Building..."
  docker build \
    --build-arg "UID=$(id -u)" \
    -t "$IMAGE" \
    "$SCRIPT_DIR"
  echo "[opencode-sandbox] Build complete."
fi

# ── Detect docker socket / DOCKER_HOST ────────────────────────────────────────
DOCKER_SOCK=""
DOCKER_GID=""
if [[ "${DOCKER_HOST:-}" == unix://* ]]; then
  # DOCKER_HOST is a unix socket — extract the path and treat like default socket
  DOCKER_SOCK="${DOCKER_HOST#unix://}"
  if [[ ! -S "$DOCKER_SOCK" ]]; then
    echo "[opencode-sandbox] Warning: $DOCKER_SOCK (from DOCKER_HOST) not found. Docker commands inside container will not work." >&2
    DOCKER_SOCK=""
  else
    DOCKER_GID=$(stat -c '%g' "$DOCKER_SOCK")
  fi
elif [[ -z "${DOCKER_HOST:-}" ]]; then
  # No DOCKER_HOST set — fall back to default socket
  DOCKER_SOCK=/var/run/docker.sock
  if [[ ! -S "$DOCKER_SOCK" ]]; then
    echo "[opencode-sandbox] Warning: $DOCKER_SOCK not found. Docker commands inside container will not work." >&2
    DOCKER_SOCK=""
  else
    DOCKER_GID=$(stat -c '%g' "$DOCKER_SOCK")
  fi
fi

# ── Detect if we are running under Podman ─────────────────────────────────────
# Podman maps the host UID to container UID 0 (root) by default in rootless mode.
# Without --userns=keep-id, host files owned by the real user appear as root inside
# the container, making them unwritable by the non-root 'coder' user (uid=1000).
IS_PODMAN=false
if docker --version 2>/dev/null | grep -qi podman; then
  IS_PODMAN=true
elif [[ "$(readlink -f "$(command -v docker)" 2>/dev/null)" == *podman* ]]; then
  IS_PODMAN=true
fi

# ── Assemble docker run args ───────────────────────────────────────────────────
RUN_ARGS=(
  "--rm"
  "--interactive"
  "--add-host" "host.docker.internal:host-gateway"
  "--volume" "$PWD:/workspace"
  "--volume" "$OPENCODE_CONFIG_DIR:/home/coder/.config/opencode:ro"
  "--volume" "$OPENCODE_SHARE_DIR:/home/coder/.local/share/opencode"
  "--workdir" "/workspace"
)

# ── Inject vars from $SANDBOX_ENV_FILE (if present) ───────────────────────────
if [[ -f "$SANDBOX_ENV_FILE" ]]; then
  while IFS= read -r _line || [[ -n "$_line" ]]; do
    # strip Windows line endings
    _line="${_line%$'\r'}"
    # skip blank lines and comments
    [[ -z "$_line" || "$_line" == \#* ]] && continue
    # strip leading 'export ' prefix
    _line="${_line#export }"
    # skip lines without '=' (not a valid KEY=VALUE pair)
    [[ "$_line" != *=* ]] && continue
    # split into key and value on the first '='
    _key="${_line%%=*}"
    _val="${_line#*=}"
    # skip lines with invalid key (must be a valid shell identifier)
    [[ "$_key" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]] || continue
    # strip surrounding single or double quotes from value
    if [[ "$_val" == \"*\" || "$_val" == \'*\' ]]; then
      _val="${_val:1:${#_val}-2}"
    fi
    RUN_ARGS+=("--env" "${_key}=${_val}")
  done < "$SANDBOX_ENV_FILE"
fi

# Shadow host .venv with a named volume so broken host symlinks are hidden.
# Named volumes work correctly with both Docker and Podman rootless (--userns=keep-id).
# The volume is keyed on the project directory path so it is reused across runs,
# avoiding redundant uv installs while remaining isolated per project.
if $ISOLATE_VENV; then
  VENV_VOLUME="opencode-venv-$(echo "$PWD" | sha256sum | cut -c1-12)"
  RUN_ARGS+=("--volume" "$VENV_VOLUME:/workspace/.venv")
fi

# Podman rootless: keep host UID mapping so mounted volumes are writable
if $IS_PODMAN; then
  RUN_ARGS+=("--userns=keep-id")
fi

[[ -t 1 ]] && RUN_ARGS+=("--tty")

if [[ -n "$DOCKER_SOCK" ]]; then
  RUN_ARGS+=("--volume" "$DOCKER_SOCK:/var/run/docker.sock")
  RUN_ARGS+=("--group-add" "$DOCKER_GID")
elif [[ -n "${DOCKER_HOST:-}" ]]; then
  # Non-unix DOCKER_HOST (tcp, ssh, etc.) — pass through as env var
  RUN_ARGS+=("--env" "DOCKER_HOST=$DOCKER_HOST")
fi

# ── Run ────────────────────────────────────────────────────────────────────────
exec docker run "${RUN_ARGS[@]}" "$IMAGE" opencode "${PASSTHROUGH_ARGS[@]}"
